{
  "name": "SUAVE Tutorial Environment (Git LFS + Codespaces Optimized)",
  "build": {
    "dockerfile": "Dockerfile",
    "context": ".",
    "args": {
      "INSTALL_EXTERNAL_TOOLS": "true",
      "SU2_DOWNLOAD_URL": "https://github.com/su2code/SU2/releases/download/v8.2.0/SU2-8.2.0-Linux.tar.gz",
      "SU2_SHA256": "fa56a890c16ca83715d7e62b351ff0528fcb92f70100129caf6382a8945b95fb",
      "AVL_DOWNLOAD_URL": "http://web.mit.edu/drela/Public/web/avl/avl3.40b.tgz"
    }
  },
  "customizations": {
    "vscode": {
      "settings": {
        "terminal.integrated.defaultProfile.linux": "bash",
        "python.defaultInterpreterPath": "/usr/local/bin/python3.9",
        "python.linting.enabled": true,
        "python.formatting.provider": "black"
      },
      "extensions": [
        "ms-python.python",
        "ms-python.pylint",
        "ms-toolsai.jupyter",
        "ms-python.black-formatter"
      ]
    }
  },
  "postCreateCommand": "set -euo pipefail; git lfs install --force; cd trunk; python3.9 setup.py develop; echo 'SUAVE environment with Git LFS ready!';",
  "postStartCommand": "python3.9 - << 'PY'\nimport sys\nprint('Python', sys.version)\nimport SUAVE, numpy, scipy, matplotlib, sklearn, plotly\nprint('✓ SUAVE + deps OK')\nPY",

  "features": {
    "ghcr.io/devcontainers/features/git:1": {},
    "ghcr.io/devcontainers/features/github-cli:1": {}
  },
  "forwardPorts": [8888, 3000, 7860]
}